# OpenPositioning Backend - Konfiguration
# Kopiere diese Datei als .env in das backend/ Verzeichnis

# MQTT Broker (meist dein Home Assistant)
MQTT_HOST=192.168.1.100
MQTT_PORT=1883
MQTT_USER=mqtt_user
MQTT_PASS=mqtt_password

# Ollama (lokal, Standard-Port)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2   # oder: mistral, phi3, gemma2

# Datenbank
DB_PATH=openpos.db

# Optional: Home Assistant Webhook für direkte Benachrichtigung
# HA_WEBHOOK_URL=http://192.168.1.100:8123/api/webhook/openpos_position
HA_WEBHOOK_URL=

# Home Assistant REST API (für KI-Steuerung)
HA_URL=http://localhost:8123
# Long-Lived Access Token: HA → Profil (unten) → Sicherheit → Token erstellen
HA_TOKEN=
